{
  "name": "notedefrais",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create notedefrais-db",
    "db:migrate": "wrangler d1 execute notedefrais-db --file=schema.sql",
    "db:migrate:local": "wrangler d1 execute notedefrais-db --local --file=schema.sql",
    "r2:create": "wrangler r2 bucket create notedefrais-images",
    "pages:deploy": "wrangler pages deploy public/"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "mindee": "^5.3.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241011.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.92.0"
  }
}
